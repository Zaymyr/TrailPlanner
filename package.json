{
  "name": "trailplanner",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @trailplanner/web",
    "build:web": "npm run build -w @trailplanner/web",
    "dev:mobile": "npm run start -w @trailplanner/mobile",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "turbo": "^2.0.0"
  }
}