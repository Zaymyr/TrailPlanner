{
  "name": "trailplanner",
  "private": true,
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "nohoist": ["**/react-native", "**/react-native/**", "**/expo", "**/expo/**", "**/expo-*", "**/expo-*/**", "**/@expo/**"]
  },
  "scripts": {
    "dev:web": "npm run dev -w @trailplanner/web",
    "build:web": "npm run build -w @trailplanner/web",
    "dev:mobile": "npm run start -w @trailplanner/mobile",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "dependencies": {
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "turbo": "^2.0.0"
  },
  "overrides": {
    "react-dom": "^18.3.1"
  }
}
